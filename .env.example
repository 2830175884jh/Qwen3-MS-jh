# The training scripts auto-load `.env` from the repo root.
# Copy this file to `.env` and fill in your local values.
# Do not commit `.env` to the public repository.

# Required only if you want SwanLab cloud logging.
# Leave blank to run without a SwanLab API key.
SWANLAB_API_KEY=

# Optional. Defaults to `cloud` when `SWANLAB_API_KEY` is set, and `local`
# when it is not set. Leave blank to use that automatic behavior.
SWANLAB_MODE=

# Optional. Local SwanLab cache/output directory.
# Defaults are set automatically by the training scripts if not provided.
SWANLAB_SAVE_DIR=

# Optional. Local SwanLab log directory.
# Defaults are set automatically by the training scripts if not provided.
SWANLAB_LOG_DIR=

# Optional. If you want to override the project name used by SwanLab, set it
# in `.env` or edit the script constants directly.
SWANLAB_PROJECT=
